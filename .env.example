# =========================================================
# WhatsApp Cloud API - بيانات الاعتماد الرسمية
# احصل عليها من: https://developers.facebook.com/apps -> تطبيقك -> WhatsApp -> API Setup
# =========================================================

# Access Token (مؤقت من لوحة التحكم 24 ساعة، أو دائم من System User)
WHATSAPP_TOKEN=PASTE_YOUR_ACCESS_TOKEN_HERE

# Phone Number ID (يظهر في API Setup أسفل رقم الواتساب)
PHONE_NUMBER_ID=PASTE_YOUR_PHONE_NUMBER_ID_HERE

# Verify Token - أي نص تختاره أنت بنفسك، ضعه أيضاً في لوحة تحكم Meta عند ضبط الـ Webhook
VERIFY_TOKEN=choose_any_secret_string_here

# منفذ تشغيل السيرفر (لوحة التحكم + Webhook على نفس المنفذ)
PORT=8080

# مفتاح Mistral AI (مطلوب لكل ميزات الذكاء الاصطناعي)
MISTRAL_API_KEY=PASTE_YOUR_MISTRAL_API_KEY_HERE

# رقم الأدمن بدون + أو رموز (مثال: 972593850520)
ADMIN_NUMBER=972593850520
